# deep skill API keys — copy to .env and fill in what you have.
# Resolution order: process env > nearest project .env > this file.

# quick + standard tiers (sonar-pro, sonar-deep-research)
PERPLEXITY_API_KEY=

# second async deep vendor (o4-mini-deep-research via Responses API background mode)
OPENAI_API_KEY=

# Gemini Deep Research standard preview -- estimated $1-3/task; background remote retention paid 55d/free 1d; no ZDR; never send local files/content.
GEMINI_API_KEY=

# optional — academic literature search; works keyless at stricter shared-pool limits
S2_API_KEY=

# authenticated scholarly search (required by current OpenAlex API)
OPENALEX_API_KEY=

# independent-index route for anti-lock-in and verification (enabled after paired benchmark)
EXA_API_KEY=

# Brave Search v2 adapter
BRAVE_SEARCH_API_KEY=
